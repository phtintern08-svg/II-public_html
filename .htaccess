# DO NOT REMOVE. CLOUDLINUX PASSENGER CONFIGURATION BEGIN
PassengerEnabled on
PassengerAppRoot "/home/impromptuindian/backend"
PassengerBaseURI "/"
PassengerPython "/home/impromptuindian/virtualenv/backend/3.11/bin/python"
PassengerAppLogFile "/home/impromptuindian/logs/passenger.log"
# DO NOT REMOVE. CLOUDLINUX PASSENGER CONFIGURATION END

RewriteEngine On

# ALWAYS send requests to Passenger (Flask) - even when static files exist
# This ensures the global lock runs on ALL requests (login.html, index.html, etc.)
# Do NOT add RewriteCond %{REQUEST_FILENAME} -f (that would bypass Flask)
RewriteRule ^(.*)$ /$1 [QSA,PT,L]
